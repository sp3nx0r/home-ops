          "instant": true,
          "legendFormat": "Files 24h Delta",
          "refId": "F"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "bucket_short", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "Time 6": true,
              "bucket 1": true,
              "bucket 2": true,
              "bucket 3": true,
              "bucket 4": true,
              "bucket 5": true,
              "bucket 6": true,
              "path 2": true,
              "path 3": true,
              "path 4": true,
              "path 5": true
            },
            "indexByName": {
              "bucket_short": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6
            },
            "renameByName": {
              "Value #A": "Scrape Success",
              "Value #B": "Size",
              "Value #C": "Files",
              "Value #D": "Newest B2 Object Age",
              "Value #E": "Size 24h Delta",
              "Value #F": "Files 24h Delta",
              "bucket_short": "Bucket"
            }
          }
        }

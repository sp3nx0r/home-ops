          "expr": "sort(label_replace(backblaze_b2_path_files_count - ((backblaze_b2_path_files_count offset 24h) or backblaze_b2_path_files_count), \"bucket_short\", \"$1\", \"bucket\", \"sp3nx0r-(.*)\"))",
          "instant": true,
          "legendFormat": "{{ bucket_short }}",
          "range": false,

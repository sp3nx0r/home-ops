        "showHeader": true
      },
      "title": "Bucket Inventory",
      "targets": [
        {
          "expr": "label_replace(backblaze_b2_scrape_success, \"bucket_short\", \"$1\", \"bucket\", \"sp3nx0r-(.*)\")",
          "format": "table",
          "instant": true,
          "legendFormat": "Scrape Success",
          "refId": "A"
        },
        {
          "expr": "label_replace(backblaze_b2_path_size_bytes, \"bucket_short\", \"$1\", \"bucket\", \"sp3nx0r-(.*)\")",
